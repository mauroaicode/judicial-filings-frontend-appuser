# Asistente de voz — proveedores: deepinfra|omnivoice (STT), deepgram|omnivoice (TTS)
# NG_APP_VOICE_STT_PROVIDER=deepinfra
# NG_APP_VOICE_TTS_PROVIDER=deepgram

# STT — DeepInfra (OpenAI-compatible)
NG_APP_DEEPINFRA_TRANSCRIPTIONS_URL=https://api.deepinfra.com/v1/audio/transcriptions
NG_APP_DEEPINFRA_STT_MODEL=openai/whisper-large-v3-turbo
NG_APP_DEEPINFRA_API_KEY=

# TTS — Deepgram REST
NG_APP_DEEPGRAM_TTS_URL=https://api.deepgram.com/v1/speak
NG_APP_DEEPGRAM_TTS_MODEL=aura-2-celeste-es
NG_APP_DEEPGRAM_API_KEY=

